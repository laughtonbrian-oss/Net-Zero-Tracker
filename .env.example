# ─── Database (Turso / LibSQL) ─────────────────────────────────────────────────
# Local development (SQLite file):
DATABASE_URL="file:./prisma/dev.db"
# Production (Turso remote):
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
AUTH_SECRET="REPLACE_WITH_32_BYTE_HEX_STRING"
# On Vercel this is set automatically — only needed for local dev:
# NEXTAUTH_URL="http://localhost:3000"

# ─── Azure AD / Microsoft Entra ID (optional — leave empty to disable SSO) ───
# Register an app at https://portal.azure.com → Azure Active Directory → App Registrations
# Redirect URI: {YOUR_DOMAIN}/api/auth/callback/microsoft-entra-id
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# Use "common" for multi-tenant, or a specific tenant ID for single-tenant
AZURE_AD_TENANT_ID=""
